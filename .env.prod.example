# Variables d'environnement de PRODUCTION.
# À renseigner dans l'onglet "Environment" du service Dokploy
# (Dokploy génère le fichier .env consommé par docker-compose.prod.yml).

# --- Strava OAuth ---
# Côté Strava (settings/api), mettre l'Authorization Callback Domain :
#   michelin.ageronjoachim.com
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_CALLBACK_URL=https://michelin.ageronjoachim.com/auth/callback

# --- Session ---
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- URLs ---
# Front et back en même origine (nginx proxy) → URL publique du domaine
FRONTEND_URL=https://michelin.ageronjoachim.com

# --- Déploiement (variable lue par docker-compose) ---
# Tag d'image à déployer : "latest", ou un SHA de commit précis pour rollback
IMAGE_TAG=latest
